# Port the backend server will listen on
PORT=3000

# The folder ID of the shared Google Drive folder where photos will be uploaded
DRIVE_FOLDER_ID=your_google_drive_folder_id_here

# Path to the service account credentials JSON file (placed in the root directory)
# Or leave empty if using the GOOGLE_SERVICE_ACCOUNT_JSON raw JSON string variable
GOOGLE_APPLICATION_CREDENTIALS=credentials.json

# (Alternative) Raw JSON string of the service account credentials. 
# Useful for production platforms like Heroku/Render where file uploading is tricky.
# GOOGLE_SERVICE_ACCOUNT_JSON='{"type": "service_account", ...}'

# Secret password required to access the admin panel and toggle uploads
ADMIN_PASSWORD=admin123
